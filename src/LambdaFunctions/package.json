{
    "name": "booking-service",
    "keywords": [],
    "author": "Abel Sintaro",
    "version": "1.0.0",
    "description": "AWS Serverless .NET 10 DDD Template with SAM",
    "scripts": {
        "debug": "dotnet lambda-test-tool-10.0",
        "build": "dotnet build",
        "build:sam": "sam build",
        "deploy:dev": "sam build && sam deploy",
        "deploy:staging": "sam build && sam deploy --config-env staging",
        "deploy:prod": "sam build && sam deploy --config-env prod",
        "api": "dotnet publish && sam local start-api",
        "validate": "sam validate"
    }
}
